# ===========================================
# Gemini AI Configuration
# ===========================================
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ===========================================
# Google Sheets Configuration
# ===========================================
# Your Google Spreadsheet ID
# Example: https://docs.google.com/spreadsheets/d/1ABCD1234567890/edit
# The ID is: 1ABCD1234567890
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SHEET_NAME=职位数据

# Service Account Credentials (JSON format - for Railway deployment)
# Copy the entire content of your service account JSON file
# IMPORTANT: In Railway, set this as a secret variable, not in .env file
# GOOGLE_CREDENTIALS_JSON={"type":"service_account",...}

# ===========================================
# Flask Configuration
# ===========================================
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=False

# ===========================================
# Scraper Configuration
# ===========================================
HEADLESS_BROWSER=True
PAGE_TIMEOUT=30000
DELAY_BETWEEN_REQUESTS=2

# ===========================================
# AI Configuration
# ===========================================
AI_MODEL=gemini-2.0-flash-exp
AI_TEMPERATURE=0.1
AI_SIMPLE_MODE=True

# ===========================================
# Railway Configuration (Auto-set)
# ===========================================
PORT=5000
